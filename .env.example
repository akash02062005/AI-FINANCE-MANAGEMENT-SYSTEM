# ============================================
# AI Finance Management - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Server ----
NODE_ENV=development
PORT=5000

# ---- MongoDB Atlas ----
# Follow MONGODB_SETUP.md for steps to get this URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_finance?retryWrites=true&w=majority

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT Secrets ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_this
JWT_REFRESH_SECRET=your_refresh_secret_here_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Stripe (Payments - optional) ----
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
ENABLE_STRIPE_PAYMENTS=false

# ---- Razorpay (Payments - default) ----
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_SfQrr3XqTwUvJH
RAZORPAY_KEY_SECRET=fXpwFsbFOLtgCNct02e76zQ5
RAZORPAY_WEBHOOK_SECRET=

# ---- Email (Nodemailer) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ---- OpenAI (for Chatbot) ----
OPENAI_API_KEY=sk-your_openai_api_key

# ---- ML Service ----
ML_SERVICE_URL=http://localhost:8000

# ---- Frontend ----
CLIENT_URL=http://localhost:3000

# ---- Admin ----
ADMIN_EMAIL=admin@yourapp.com
ADMIN_PASSWORD=change_this_admin_password
