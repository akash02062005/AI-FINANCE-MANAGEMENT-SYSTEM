# ============================================================
# AI Finance Management — server .env.example
# Copy to `.env` and fill in REAL values. Demo mode has been removed;
# the server refuses to boot if the "hard requirements" are missing.
#
# >> For a 100% free-tier setup (no credit card), see SETUP_FREE.md
# >> For the full paid-provider guide, see SETUP_REAL.md
#
# Free-tier cheat sheet:  MONGODB_URI + GEMINI_API_KEY + HF_API_KEY
# plus the two JWT secrets you generate yourself. Leave OPENAI/ANTHROPIC blank.
# ============================================================

# ---------- Runtime ----------
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ---------- HARD REQUIREMENTS (server exits if any of these are missing) ----------
# Your full MongoDB Atlas connection string, including a database name and password.
# Example:
# mongodb+srv://myuser:mypass@cluster0.abc12.mongodb.net/ai_finance?retryWrites=true&w=majority
MONGODB_URI=<paste your mongodb atlas connection string>
# Optional: Node's SRV resolver can fail on some Windows networks unless public DNS is explicit.
DNS_SERVERS=8.8.8.8,8.8.4.4,1.1.1.1

# Generate via: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<64+ char random string>
JWT_REFRESH_SECRET=<different 64+ char random string>
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ---------- Admin bootstrap (idempotent — runs only if user doesn't exist) ----------
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=<strong password, 16+ chars>
ADMIN_NAME=Administrator

# ---------- LLM providers (at least ONE is required for chat / OCR) ----------
# Gemini is recommended as primary OCR (multimodal, generous free tier)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional 4th fallback
HF_API_KEY=
HF_CHAT_MODELS=meta-llama/Llama-3.1-8B-Instruct:novita,openai/gpt-oss-20b:fireworks-ai,HuggingFaceH4/zephyr-7b-beta:featherless-ai
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-flash-latest

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---------- Redis (optional — cache + rate limit; server continues without it) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- Email (optional — notifications) ----------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ai-finance.local

# ---------- Stripe (optional — paid tiers) ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- URLs ----------
APP_URL=http://localhost:5173
API_URL=http://localhost:5000

# ---------- Python ML microservice (optional) ----------
ML_SERVICE_URL=http://localhost:8000

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- Feature flags ----------
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_STRIPE_PAYMENTS=false
ENABLE_ML_FEATURES=true
ENABLE_TEAM_FEATURES=true

# ---------- External APIs — Currency (optional) ----------
EXCHANGE_RATE_API_KEY=
OPEN_EXCHANGE_RATES_API_KEY=

# ---------- External APIs — Stock Market (optional) ----------
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# ---------- External APIs — News (optional) ----------
NEWS_API_KEY=
GNEWS_API_KEY=

# ---------- External APIs — Investments (optional) ----------
COINGECKO_API_KEY=
METALS_API_KEY=

# ---------- Payment APIs (optional) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
