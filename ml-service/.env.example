# AI Finance ML Microservice Configuration

# Environment
ENV=development
DEBUG=True

# API Configuration
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=ai_finance_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI API (optional for chatbot)
OPENAI_API_KEY=your_openai_api_key_here

# Feature Flags
ENABLE_CHATBOT=True
ENABLE_ANOMALY_DETECTION=True
ENABLE_PREDICTIONS=True
ENABLE_PERSONALITY_ANALYSIS=True

# Logging
LOG_LEVEL=INFO
